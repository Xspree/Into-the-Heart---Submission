    "Secret_Reading1": {
      "Position": {
        "X": -17.625,
        "Y": 166.0,
        "Z": 166.0
      },
      "Shape": {
        "Type": "Box",
        "Min": {
          "X": -0.625,
          "Y": -1.0,
          "Z": -4.0
        },
        "Max": {
          "X": 0.625,
          "Y": 1.0,
          "Z": 4.0
        }
      },
      "Effects": [
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 0.0,
          "Message": "\" Orbis' Beginning \" : From nothingness as we know it, life is born where the avatar commands it."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 2.75,
          "Message": "\" Orbis' Beginning \" : Orbis was formed from 6 elements of Gaia. Normally worlds consistent of one to three elements, but there are rare conditions."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 7.0,
          "Message": "\" Orbis' Beginning \" : From that moment Orbis became a world to welcome any and all elementally beings. Cosmic or not, Gaia thrived to fill her world with everyone. . ."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 10.0,
          "Message": "The book beginnings to fade"
        }
      ],
      "TargetTypes": [
        "Player"
      ],
      "Enabled": true,
      "KeepLoaded": false,
      "Cooldown": 10.0,
      "Tags": {
        "Ending1_Not_Triggered": "Empty"
      }
    },
    "Secret_Reading2": {
      "Position": {
        "X": -17.625,
        "Y": 166.0,
        "Z": 189.0
      },
      "Shape": {
        "Type": "Box",
        "Min": {
          "X": -0.625,
          "Y": -1.0,
          "Z": -4.0
        },
        "Max": {
          "X": 0.625,
          "Y": 1.0,
          "Z": 4.0
        }
      },
      "Effects": [
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 0.0,
          "Message": "\" The Grand Ceremony \" : Gaia's opening of Orbis starts with the event known as \"The Grand Ceremony\". Every world has one when it comes time to unitying with the Alterverse."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 4.0,
          "Message": "\" The Grand Ceremony \" : Orbis grew to a large spectual for avatars due to the nature of its vast power of elements. It was one of the few worlds that could allow many users from different worlds to visit."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 8.0,
          "Message": "\" The Grand Ceremony \" : Given the circumstance of Orbis, avatars from all around the Alterverse came to join in the celebration. The day brought forth many drag. . ."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 10.0,
          "Message": "The book beginnings to fade"
        }
      ],
      "TargetTypes": [
        "Player"
      ],
      "Enabled": true,
      "KeepLoaded": false,
      "Cooldown": 10.0,
      "Tags": {
        "Ending1_Not_Triggered": "Empty"
      }
    },
    "Secret_Reading3": {
      "Position": {
        "X": -21.0,
        "Y": 171.0,
        "Z": 188.5
      },
      "Shape": {
        "Type": "Box",
        "Min": {
          "X": -1.0,
          "Y": -1.0,
          "Z": -3.5
        },
        "Max": {
          "X": 1.0,
          "Y": 1.0,
          "Z": 3.5
        }
      },
      "Effects": [
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 0.0,
          "Message": "\" The Adventures of Gaia \" : Many have speculated that Gaia has gone on adventures with real guild mates!"
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 3.0,
          "Message": "\" The Adventures of Gaia \" : She goes under the alias Terra, but classifies as a witch for her class qualifications!"
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 6.0,
          "Message": "\" The Adventures of Gaia \" : I have followed loosely behind her dungeon groups, but have made sure to document illustrations of her spell stances and weapon she uses. . ."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 10.0,
          "Message": "The book beginnings to fade"
        }
      ],
      "TargetTypes": [
        "Player"
      ],
      "Enabled": true,
      "KeepLoaded": false,
      "Cooldown": 10.0,
      "Tags": {
        "Ending1_Not_Triggered": "Empty"
      }
    },
    "Secret_Reading4": {
      "Position": {
        "X": -21.0,
        "Y": 171.0,
        "Z": 176.5
      },
      "Shape": {
        "Type": "Box",
        "Min": {
          "X": -1.0,
          "Y": -1.0,
          "Z": -3.5
        },
        "Max": {
          "X": 1.0,
          "Y": 1.0,
          "Z": 3.5
        }
      },
      "Effects": [
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 0.0,
          "Message": "\" The Slothians \" : Amongst the many factions that have called Orbis home, there lives one who are the deadliest."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 3.0,
          "Message": "\" The Slothians \" : Their leader - Simon - has been known to be a peaceful commander, but in recent riots from the Huge Fist, Simon dominated the field. "
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 7.0,
          "Message": "\" The Slothians \" : Their slow movements in combat can only be related to seeing frames repeated before ones eyes. Before anyone realizes what has happened, the battle has already been decided. . ."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 10.0,
          "Message": "The book beginnings to fade"
        }
      ],
      "TargetTypes": [
        "Player"
      ],
      "Enabled": true,
      "KeepLoaded": false,
      "Cooldown": 10.0,
      "Tags": {
        "Ending1_Not_Triggered": "Empty"
      }
    },
    "Secret_Reading5": {
