    "Book_Reading_Zerk1": {
      "Position": {
        "X": -9.5,
        "Y": 160.0,
        "Z": 190.0
      },
      "Shape": {
        "Type": "Box",
        "Min": {
          "X": -0.5,
          "Y": -1.0,
          "Z": -3.0
        },
        "Max": {
          "X": 0.5,
          "Y": 1.0,
          "Z": 3.0
        }
      },
      "Effects": [
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 0.0,
          "Message": "\" Zerk's Legacy \": Zerk grew up as an only child. His upcoming was not in the greatest places of the Alterverse."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 3.0,
          "Message": "\" Zerk's Legacy \": However, Zerk knew there was something he could do to help his family. He worked his way through schooling to join the councilmen."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 7.0,
          "Message": "\" Zerk's Legacy \": Many opposed this outcome because only the truly gifted were allowed. Regardless Zerk overcame the outcomes and was able to asc. . ."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 11.0,
          "Message": "The rest of the book has started to fade."
        },
        {
          "Type": "ModifyTags",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 0.0,
          "Operation": "Remove",
          "TagKey": "Searchable",
          "TagValue": "Empty",
          "MatchKey": "",
