    "Secret_Reading6": {
      "Position": {
        "X": 16.0,
        "Y": 171.0,
        "Z": 188.5
      },
      "Shape": {
        "Type": "Box",
        "Min": {
          "X": -1.0,
          "Y": -1.0,
          "Z": -3.5
        },
        "Max": {
          "X": 1.0,
          "Y": 1.0,
          "Z": 3.5
        }
      },
      "Effects": [
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 0.0,
          "Message": "\" A Hawk, Kweebec, & Trork \" : \"A quick adventure into the unknown\" says the Kweebec. He has always been enthusiastic about these adventures. Hardle anyone in the guild has paid attention these days."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 5.0,
          "Message": "\" A Hawk, Kweebec, & Trork \" : \"Only if I can bring my notebook along!\" the Hawk states. \"I need to be able to document what we find!\" The Trork stares blankly at both of them with a wide mouth."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 10.0,
          "Message": "\" A Hawk, Kweebec, & Trork \" : \"So. . . are you in Trork?\" Kweebec hesitantly asked. \"Look what I made!\" Trork slams down a brand new contraption he was daydreaming about. . ."
        },
        {
          "Type": "SendMessage",
          "Event": "ENTER",
          "Interval": 0.0,
          "Delay": 14.0,
          "Message": "The book beginnings to fade"
        }
      ],
      "TargetTypes": [
        "Player"
      ],
      "Enabled": true,
      "KeepLoaded": false,
      "Cooldown": 15.0
    },
